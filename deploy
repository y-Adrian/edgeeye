#!/bin/sh
# 用法：
#   ./deploy           上传 output/ 下所有产物 + scripts/ + sensor ini + ffmpeg
#   ./deploy debris.ko 只上传指定文件
set -e

BOARD_IP=192.168.42.1
BOARD_USER=root
BOARD_DIR=/root
ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
OUT_DIR="$ROOT_DIR/output"
SCRIPT_DIR="$ROOT_DIR/scripts"
FFMPEG_STAGE="$OUT_DIR/ffmpeg-riscv64-static"

edgeeye_deploy_ffmpeg() {
	if [ ! -x "$FFMPEG_STAGE" ]; then
		return 0
	fi
	if ! "$FFMPEG_STAGE" -hide_banner -muxers 2>/dev/null | grep -qE '[[:space:]]hls[[:space:]]'; then
		echo "WARN: $FFMPEG_STAGE lacks HLS muxer — skip ffmpeg deploy" >&2
		echo "      rerun: ./scripts/build_ffmpeg_cli.sh" >&2
		return 0
	fi
	echo "deploy ffmpeg -> /mnt/data/bin/ffmpeg"
	ssh "$BOARD_USER@$BOARD_IP" "mkdir -p /mnt/data/bin"
	scp "$FFMPEG_STAGE" "$BOARD_USER@$BOARD_IP:/mnt/data/bin/ffmpeg"
	ssh "$BOARD_USER@$BOARD_IP" "chmod +x /mnt/data/bin/ffmpeg"
}

if [ -n "$1" ]; then
	scp "$OUT_DIR/$1" "$BOARD_USER@$BOARD_IP:$BOARD_DIR/"
	exit 0
fi

FILES=$(find "$OUT_DIR" -maxdepth 1 -type f -not -name '.*' -not -name 'ffmpeg-riscv64-static' 2>/dev/null)
if [ -z "$FILES" ] && [ ! -x "$FFMPEG_STAGE" ]; then
	echo "output/ is empty, run make first"
	exit 1
fi

if [ -n "$FILES" ]; then
	scp $FILES "$BOARD_USER@$BOARD_IP:$BOARD_DIR/"
fi
edgeeye_deploy_ffmpeg
for s in \
	run_edgeeye_cam.sh run_edgeeye_stack.sh stop_edgeeye_stack.sh \
	edgeeye_cam_common.sh edgeeye_snapshots.sh serve_edgeeye_web.sh \
	edgeeye_hls.sh edgeeye_http_server.py \
	install_autostart.sh health_check.sh stability_6h.sh \
	start_my_cam_rtsp.sh stop_my_cam_rtsp.sh preview_my_cam_rtsp_mac.sh \
	my_cam_test_common.sh record_clip.sh media_tools.sh stop_motion_recorder.sh \
	build_ffmpeg_cli.sh install_ffmpeg_cli_board.sh install_ffprobe_board.sh \
	setup_wifi_board.sh check_wifi_board.sh check_lan_live_board.sh \
	check_ai_event_log_board.sh check_ai_grab_frame_board.sh \
	check_ai_person_detect_board.sh ai_person_detect.sh install_tdl_libs_board.sh \
	test_my_cam_test.sh test_my_cam_test_phase.sh \
	test_my_cam_test_phase3.sh test_my_cam_test_phase4.sh test_my_cam_test_phase5.sh \
	test_my_cam_test_phase6.sh test_my_cam_test_phase7.sh test_my_cam_test_phase8.sh \
	test_my_cam_test_dual.sh test_my_cam_test_suite.sh
do
    if [ -f "$SCRIPT_DIR/$s" ]; then
        scp "$SCRIPT_DIR/$s" "$BOARD_USER@$BOARD_IP:$BOARD_DIR/"
    fi
done
if [ -d "$OUT_DIR/stream" ]; then
    ssh "$BOARD_USER@$BOARD_IP" "mkdir -p $BOARD_DIR/stream"
    scp -r "$OUT_DIR/stream/"* "$BOARD_USER@$BOARD_IP:$BOARD_DIR/stream/"
fi
if [ -f "$ROOT_DIR/configs/edgeeye_cam.conf" ]; then
    scp "$ROOT_DIR/configs/edgeeye_cam.conf" "$BOARD_USER@$BOARD_IP:$BOARD_DIR/"
fi
if [ -d "$ROOT_DIR/web" ]; then
    ssh "$BOARD_USER@$BOARD_IP" "mkdir -p $BOARD_DIR/web/snapshots"
    scp -r "$ROOT_DIR/web/"* "$BOARD_USER@$BOARD_IP:$BOARD_DIR/web/"
fi
echo "deployed to $BOARD_USER@$BOARD_IP:$BOARD_DIR"
